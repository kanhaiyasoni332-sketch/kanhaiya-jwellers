<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Section Heading -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_transaction"
            android:textColor="@color/gold_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:layout_marginBottom="24dp" />

        <!-- Customer Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCustomerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/customer_name"
            style="@style/Widget.KanhaiyaJewellers.TextInputLayout"
            android:layout_marginBottom="14dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCustomerName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName|textCapWords"
                android:minHeight="54dp"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Phone Number -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPhoneNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/phone_number"
            style="@style/Widget.KanhaiyaJewellers.TextInputLayout"
            android:layout_marginBottom="14dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPhoneNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="phone"
                android:minHeight="54dp"
                android:maxLength="10"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Item Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilItemName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/item_name"
            style="@style/Widget.KanhaiyaJewellers.TextInputLayout"
            android:layout_marginBottom="14dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etItemName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:minHeight="54dp"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Item Weight -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilItemWeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/item_weight"
            style="@style/Widget.KanhaiyaJewellers.TextInputLayout"
            android:layout_marginBottom="14dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etItemWeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:minHeight="54dp"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Promise Return Date -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPromiseDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/promise_return_date"
            style="@style/Widget.KanhaiyaJewellers.TextInputLayout"
            android:layout_marginBottom="14dp"
            app:endIconMode="custom"
            app:endIconDrawable="@android:drawable/ic_menu_my_calendar">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPromiseDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="true"
                android:inputType="none"
                android:minHeight="54dp"
                android:hint="@string/select_date"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Total Amount -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilTotalAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/total_amount"
            style="@style/Widget.KanhaiyaJewellers.TextInputLayout"
            android:layout_marginBottom="14dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTotalAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:minHeight="54dp"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Paid Amount -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPaidAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/paid_amount"
            style="@style/Widget.KanhaiyaJewellers.TextInputLayout"
            android:layout_marginBottom="20dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPaidAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:minHeight="54dp"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Remaining Amount Live Preview -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:orientation="horizontal"
            android:layout_marginBottom="28dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/remaining_amount"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvRemainingValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0.00"
                android:textColor="@color/gold_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Save Button -->
        <Button
            android:id="@+id/btnSaveTransaction"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="@string/save_transaction"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="16sp"
            android:background="@drawable/bg_gold_button"
            android:letterSpacing="0.06" />

    </LinearLayout>
</ScrollView>
