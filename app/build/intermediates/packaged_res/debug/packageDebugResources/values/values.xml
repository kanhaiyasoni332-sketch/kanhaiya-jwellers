    <style name="Widget.KanhaiyaJewellers.Button.Gold" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/black</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="backgroundTint">@color/gold_primary</item>
        <item name="cornerRadius">8dp</item>
    </style>
    <style name="Widget.KanhaiyaJewellers.Button.Gold.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/gold_primary</item>
        <item name="strokeColor">@color/gold_primary</item>
    </style>
    <style name="Widget.KanhaiyaJewellers.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/gold_primary</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="hintTextColor">@color/gold_primary</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="startIconTint">@color/gold_primary</item>
        <item name="endIconTint">@color/gold_primary</item>
    </style>
    <style name="Widget.KanhaiyaJewellers.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/background_primary</item>
        <item name="android:elevation">0dp</item>
        <item name="titleTextColor">@color/gold_primary</item>
        <item name="subtitleTextColor">@color/text_secondary</item>
        <item name="navigationIconTint">@color/gold_primary</item>
