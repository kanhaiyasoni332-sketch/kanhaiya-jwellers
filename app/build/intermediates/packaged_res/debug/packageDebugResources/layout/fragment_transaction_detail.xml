<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Customer Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Customer"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.08"
            android:textAllCaps="true"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvCustomerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider" android:layout_marginBottom="20dp" />

        <!-- Item Name -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Item"
                android:textColor="@color/text_secondary" android:textSize="13sp" />
            <TextView android:id="@+id/tvItemName" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="—" android:textColor="@color/text_primary"
                android:textSize="13sp" android:gravity="end" />
        </LinearLayout>

        <!-- Item Weight -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/item_weight"
                android:textColor="@color/text_secondary" android:textSize="13sp" />
            <TextView android:id="@+id/tvItemWeight" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="—" android:textColor="@color/text_primary"
                android:textSize="13sp" android:gravity="end" />
        </LinearLayout>

        <!-- Created On -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/created_on"
                android:textColor="@color/text_secondary" android:textSize="13sp" />
            <TextView android:id="@+id/tvCreatedAt" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="—" android:textColor="@color/text_primary"
                android:textSize="13sp" android:gravity="end" />
        </LinearLayout>

        <!-- Promise Return Date -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/promise_return_date"
                android:textColor="@color/text_secondary" android:textSize="13sp" />
            <TextView android:id="@+id/tvPromiseDate" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="—" android:textColor="@color/text_primary"
                android:textSize="13sp" android:gravity="end" />
        </LinearLayout>

        <!-- Total Amount -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Total Amount"
                android:textColor="@color/text_secondary" android:textSize="13sp" />
            <TextView android:id="@+id/tvTotalAmount" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="₹0.00" android:textColor="@color/text_primary"
                android:textSize="13sp" android:gravity="end" />
        </LinearLayout>

        <!-- Paid Amount -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Paid Amount"
                android:textColor="@color/text_secondary" android:textSize="13sp" />
            <TextView android:id="@+id/tvPaidAmount" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="₹0.00" android:textColor="@color/status_completed"
                android:textSize="13sp" android:gravity="end" />
        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider" android:layout_marginBottom="12dp" />

        <!-- Remaining Amount -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="20dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Remaining Amount"
                android:textColor="@color/text_primary" android:textSize="15sp"
                android:textStyle="bold" />
            <TextView android:id="@+id/tvRemainingAmount" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="₹0.00" android:textColor="@color/gold_primary"
                android:textSize="18sp" android:textStyle="bold" android:gravity="end" />
        </LinearLayout>

        <!-- Status Badge -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="●  PENDING"
            android:textColor="@color/status_pending"
            android:background="@drawable/bg_status_pending"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:layout_marginBottom="28dp" />

        <!-- Payment History Header -->
        <TextView
            android:id="@+id/tvPaymentHistoryLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PAYMENT HISTORY"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:letterSpacing="0.08"
            android:textAllCaps="true"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <!-- Payments RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPayments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="24dp"
            android:visibility="gone" />

        <!-- Add Payment Button -->
        <Button
            android:id="@+id/btnAddPayment"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="@string/add_payment"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="16sp"
            android:background="@drawable/bg_gold_button"
            android:letterSpacing="0.04" />

        <Button
            android:id="@+id/btnWhatsappReminder"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:text="@string/send_whatsapp_reminder"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="15sp"
            android:background="@drawable/bg_gold_button"
            android:letterSpacing="0.02" />

        <Button
            android:id="@+id/btnThankYouMessage"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:text="@string/send_thank_you_message"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="15sp"
            android:background="@drawable/bg_gold_button"
            android:letterSpacing="0.02"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
